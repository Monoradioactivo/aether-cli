{
  "name": "@aetherpush/cli",
  "version": "0.3.2",
  "description": "Command-line interface for Aether — over-the-air updates for React Native apps.",
  "main": "./bin/script/index.js",
  "types": "./bin/script/index.d.ts",
  "scripts": {
    "start": "node ./bin/script/cli.js",
    "build": "tsc",
    "clean": "rimraf bin",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --write \"./**/*.ts\"",
    "lint": "npx eslint ./script/**/*.ts",
    "lint:fix": "npx eslint ./script/**/*.ts --fix",
    "test": "jest"
  },
  "bin": {
    "aether": "bin/script/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Monoradioactivo/aether-cli.git"
  },
  "author": "Aether",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Monoradioactivo/aether-cli/issues"
  },
  "homepage": "https://github.com/Monoradioactivo/aether-cli#readme",
  "keywords": [
    "aether",
    "aetherpush",
    "react-native",
    "ota",
    "codepush",
    "cli",
    "deployment",
    "updates"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "backslash": "^0.2.0",
    "chalk": "^4.1.2",
    "cli-table": "^0.3.11",
    "email-validator": "^2.0.4",
    "gradle-to-js": "2.0.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "parse-duration": "^2.1.6",
    "plist": "^3.1.1",
    "progress": "^2.0.3",
    "prompt": "^1.3.0",
    "properties": "^1.2.1",
    "rimraf": "^2.5.1",
    "semver": "^7.5.3",
    "simctl": "^3.0.0",
    "temp": "^0.9.4",
    "which": "^7.0.0",
    "wordwrap": "1.0.0",
    "xcode": "^3.0.1",
    "xml2js": "^0.6.0",
    "yargs": "^17.7.2",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^8.45.0",
    "jest": "^30.4.2",
    "prettier": "^2.8.8",
    "ts-jest": "^29.4.10",
    "typescript": "^5.1.3",
    "yauzl": "^3.3.0"
  }
}
